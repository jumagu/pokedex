# Dependencies (reinstalled inside the image)
node_modules
.pnpm-store

# Build output (regenerated by `pnpm run build`)
dist

# Environment & secrets — never bake these into an image
.env
.env.*
!.env.example

# Version control & CI
.git
.gitignore
.github

# Docker
Dockerfile
.dockerignore
docker-compose*.yml

# Tests & coverage
coverage
test

# Editor / OS cruft
.vscode
.idea
.DS_Store

# Docs & meta
README.md
*.md

# Tooling caches / config not needed at build time
.eslintrc*
eslint.config.*
.prettierrc*
